# リッスンポート（デフォルト: 8080）
PORT=8080

# Postgres database URL
# Format: postgres://user:pass@host:port/dbname?sslmode=require
# leapcell.io 上では Postgres add-on が DATABASE_URL を自動注入する想定。
# ローカル開発では docker-compose の postgres サービスを指す。
DATABASE_URL=postgres://postgres:postgres@localhost:5432/resume_2026?sslmode=disable

# CORS 許可 Origin（カンマ区切り）
CORS_ORIGINS=http://localhost:3000

# 許可コードの SHA-256 ハッシュ（カンマ区切り）
# 生成方法: echo -n "コード文字列" | shasum -a 256
# ⚠ 本番では必ず独自のハッシュに変更すること
AUTH_CODE_HASHES=<your-sha256-hash>
