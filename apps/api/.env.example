# リッスンポート（デフォルト: 8080）
PORT=8080

# SOPS 復号済み seed YAML を base64 化した値。
# 生成例:
# sops -d --input-type binary --output-type binary apps/api/seed/app-data.sops.bin | base64 | tr -d '\n'
# APP_DATA_YAML_B64=

# CORS 許可 Origin（カンマ区切り）
CORS_ORIGINS=http://localhost:3000

# referral code (= ユーザー) は seed YAML の users セクションで管理する。
